import pandas as pd
import matplotlib.pyplot as plt
from statsmodels.tsa.arima.model import ARIMA
from sklearn.metrics import mean_absolute_error, mean_squared_error
import numpy as np
import warnings
import plotly.express as px

# Suppress warnings
warnings.filterwarnings("ignore")

# Load dataset
file_path = "hd.csv"  # Update this with the correct path
df = pd.read_csv(file_path)

# Convert Timestamp to datetime format
df["Timestamp"] = pd.to_datetime(df["Timestamp"])
df.set_index("Timestamp", inplace=True)

# Aggregate transaction amounts by day
df_daily = df["Amount (INR)"].resample("D").sum()

# Split into train and test sets (80% train, 20% test)
train_size = int(len(df_daily) * 0.8)
train, test = df_daily[:train_size], df_daily[train_size:]

# Fit ARIMA model (p=1, d=1, q=1)
model = ARIMA(train, order=(1, 1, 1))
model_fit = model.fit()

# Forecast for the test period
forecast = model_fit.forecast(steps=len(test))

# Calculate Accuracy Metrics
mae = mean_absolute_error(test, forecast)
mse = mean_squared_error(test, forecast)
rmse = np.sqrt(mse)
accuracy = 100 - (mae / test.mean() * 100)  # Accuracy estimation

print(f"Mean Absolute Error: {mae:.2f} INR")
print(f"Mean Squared Error: {rmse:.2f} INR")
print(f"Estimated Accuracy: {accuracy:.2f}%")

# Plot actual vs predicted values
plt.figure(figsize=(10, 5))
plt.plot(train, label="Train")
plt.plot(test, label="Test", color="orange")
plt.plot(test.index, forecast, label="Forecast", color="red", linestyle="dashed")
plt.legend()
plt.title("ARIMA Forecast vs Actual Transaction Amounts")
plt.xlabel("Date")
plt.ylabel("Transaction Amount (INR)")
plt.show()

# Aggregate total transaction amount by platform
platform_totals = df.groupby("Platform")["Amount (INR)"].sum()

# Plot the bar chart
plt.figure(figsize=(10, 5))
platform_totals.sort_values(ascending=False).plot(kind="bar",color='green')
plt.title("Total Transaction Amount by Platform")
plt.xlabel("Payment Platform")
plt.ylabel("Total Amount (INR)")
plt.xticks(rotation=45)
plt.grid(axis="y", linestyle="--", alpha=0.7)
plt.show()

# Aggregate total transaction amount by category
category_totals = df.groupby("Category")["Amount (INR)"].sum().reset_index()

# Find the most sold item in each category
most_sold_items = df.groupby(["Category", "Item"]).size().reset_index(name="Count")
most_sold_items = most_sold_items.loc[most_sold_items.groupby("Category")["Count"].idxmax()]

# Merge with category totals
category_totals = category_totals.merge(most_sold_items[["Category", "Item"]], on="Category", how="left")

# Create interactive bar chart
fig = px.bar(
    category_totals,
    x="Category",
    y="Amount (INR)",
    title="Total Sales Amount by Category",
    labels={"Amount (INR)": "Total Amount (INR)", "Category": "Category"},
    text="Item",  # Show most sold item as text on bars
    hover_data={"Item": True}  # Show most sold item on hover
)

# Adjust text position and layout for better readability
fig.update_traces(marker_color="#ff7f0e", textposition="inside")  # Inside bars for better visibility
fig.update_layout(
    xaxis_tickangle=-45,  # Rotate labels
    uniformtext_minsize=10,  # Ensure text size is readable
    uniformtext_mode='hide'  # Hide overlapping text instead of cutting it off
)

# Show the interactive chart
fig.show()

# Create an interactive pie chart
fig = px.pie(
    category_totals,
    names="Category",
    values="Amount (INR)",
    title="Sales Distribution by Category",
    hover_data={"Amount (INR)": ":,.2f"},  # Show formatted sales amount on hover
    hole=0.3  # Creates a donut-style pie chart
)

# Show the interactive chart
fig.show()
